# =====================================================================
# live/.env.example — 模板（进 git，供他人参考）
# =====================================================================
# 复制为 live/.env 并填充真值后使用
# cp live/.env.example live/.env

# ---------------------------------------------------------------------
# 云 PG — 阿里云 RDS / 腾讯云 CDB / 自建 PostgreSQL 16+
# ---------------------------------------------------------------------
# 密码含特殊字符需 URL 编码：$ → %24，# → %23，@ → %40
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DBNAME
DATABASE_URL_ASYNC=postgresql+asyncpg://USERNAME:PASSWORD@HOST:5432/DBNAME

# ---------------------------------------------------------------------
# Server 酱 SendKey（微信推送） — https://sct.ftqq.com/
# ---------------------------------------------------------------------
SERVERCHAN_SEND_KEY=SCT12345abcdef

# ---------------------------------------------------------------------
# 阿里云短信 SMS（一期可空，留空时 alerting 降级为 stub）
# ---------------------------------------------------------------------
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
PHONE_NUMBER=

# ---------------------------------------------------------------------
# 业务参数
# ---------------------------------------------------------------------
SOFT_STOP_PCT=0.05
APP_TIMEZONE=Asia/Shanghai
