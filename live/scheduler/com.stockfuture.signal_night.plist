<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>TZ</key>
		<string>Asia/Shanghai</string>
	</dict>
	<key>Label</key>
	<string>com.stockfuture.signal_night</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-lc</string>
		<string>/Users/mm/opt/miniconda3/bin/python -m live.signal_service --date $(date +%Y-%m-%d) --session night</string>
	</array>
	<key>RunAtLoad</key>
	<false/>
	<key>StandardErrorPath</key>
	<string>/Users/mm/Trading/stock-future/live/logs/launchd/signal_night.err.log</string>
	<key>StandardOutPath</key>
	<string>/Users/mm/Trading/stock-future/live/logs/launchd/signal_night.out.log</string>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>17</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>
	<key>WorkingDirectory</key>
	<string>/Users/mm/Trading/stock-future</string>
</dict>
</plist>
